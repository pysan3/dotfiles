{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(bazel run //tools/*)",
      "Bash(bazel test:*)",
      "Bash(npx markdownlint-cli:*)",
      "Bash(python -m pytest:*)",
      "Bash(mypy:*)",
      "Bash(pyright:*)",
      "Bash(poetry run ruff:*)"
    ],
    "defaultMode": "default"
  },
  "theme": "dark",
  "model": "opus[1m]"
}
