{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh api *annotations*)",
      "Bash(gh api *commits*)",
      "Bash(gh api *comments*)",
      "Bash(gh api *reviews*)",
      "Bash(gh api *status*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git log :*)",
      "Bash(git --no-pager log :*)",
      "Bash(git show :*)",
      "Bash(git --no-pager show :*)",
      "Bash(git diff :*)",
      "Bash(git --no-pager diff :*)",
      "Bash(bazel run //tools/*)",
      "Bash(bazel test:*)",
      "Bash(npx markdownlint-cli:*)",
      "Bash(NO_UPDATE_NOTIFIER=1 npx markdownlint-cli:*)",
      "Bash(python -m pytest:*)",
      "Bash(mypy:*)",
      "Bash(pyright:*)",
      "Bash(poetry run ruff:*)"
    ],
    "ask": [
      "Bash(gh api *-X*)",
      "Bash(gh api *--method*)",
      "Bash(gh api *-f*)",
      "Bash(gh api *--field*)",
      "Bash(gh api *-F*)",
      "Bash(gh api *--raw-field*)",
      "Bash(gh api *--input*)"
    ],
    "defaultMode": "default"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$XDG_DATA_HOME/tmux/plugins/tmux-claude-session-manager/scripts/state.sh working"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$XDG_DATA_HOME/tmux/plugins/tmux-claude-session-manager/scripts/state.sh waiting"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "$XDG_DATA_HOME/tmux/plugins/tmux-claude-session-manager/scripts/state.sh waiting"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$XDG_DATA_HOME/tmux/plugins/tmux-claude-session-manager/scripts/state.sh idle"
          }
        ]
      }
    ]
  },
  "theme": "dark",
  "skipWorkflowUsageWarning": true
}
