#!/usr/bin/env zsh

local old="${1}"
local origin="origin"
local current=$(git branch --show-current)
local master="${2:-master}"
local target="$origin/$master"

echo "🌐 Fetching latest from '$origin' and pruning dead branches..."
git fetch --quiet --prune "$origin"

local wt=$(git worktree list 2>/dev/null | command grep " \[$master\]$" | awk '{print $1}')
if [[ -n "$wt" ]]; then
  echo "📂 Fast-forwarding '$master' worktree at '$wt'..."
  git -C "$wt" merge --quiet --ff-only "$target" 2>/dev/null
fi

if [[ -z "$old" ]]; then
  old=$(git rev-parse --abbrev-ref HEAD@{upstream} 2>/dev/null)
  [[ "$old" == "$origin/"* ]] && old=""

  if [[ -z "$old" ]]; then
    old=$(git log --simplify-by-decoration --format="%D" "$target..HEAD~1" --decorate-refs="refs/heads/*" 2>/dev/null | command grep -m 1 "." | cut -d, -f1)
  fi
fi

if [[ -z "$old" || "$old" == "$master" || "$old" == "$target" ]]; then
  echo "❌ Error: Cannot auto-detect parent branch." >&2
  echo "Usage: gsync [old] [master]" >&2
  return 1
fi

# --- THE MAGIC FOR Z and Z' ---
# 1. Record the exact commit hash of Y BEFORE we move it
local old_current_hash=$(git rev-parse HEAD)

# 2. Find all branches that contain this commit (excluding Y itself)
local dependents=($(git branch --contains "$old_current_hash" --format='%(refname:short)' | command grep -v "^${current}$"))

echo "🔍 Auto-detected parent branch: $old"
echo "🔄 Rebasing '$current' onto '$target' (dropping '$old' commits)..."

# 3. Rebase Y onto master
if ! git rebase --onto "$target" "$old" "$current"; then
  echo "❌ Rebase failed. Please resolve conflicts." >&2
  return 1
fi

# 4. Automatically transplant all dependent branches onto the new Y
if (( ${#dependents[@]} > 0 )); then
  echo "🌿 Auto-syncing dependent branches: ${dependents[*]}"
  for dep in "${dependents[@]}"; do
    echo "   -> Transplanting '$dep' onto new '$current'..."
    # --update-refs here ensures if Z has its own linear stack, it moves cleanly too
    git rebase --onto "$current" "$old_current_hash" "$dep" --update-refs >/dev/null 2>&1
  done

  # 5. Return you to the branch you started on
  git checkout "$current" --quiet
  echo "✅ Finished syncing all branches in the tree."
fi
